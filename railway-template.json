{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "Ghost ProtoClaw — AI Business Control Panel",
  "description": "Deploy Ghost ProtoClaw (AI mission control) + AI runtimes (Hermes, Codex, Claude Code) + PostgreSQL. One-click deploy — just bring your OpenRouter API key.",
  "icon": "https://raw.githubusercontent.com/beardfacebeard/Ghost-ProtoClaw/main/public/favicon.ico",
  "services": {
    "GhostProtoClaw": {
      "name": "Ghost ProtoClaw",
      "description": "AI Mission Control panel — manages agents, workflows, knowledge base, and runtimes.",
      "source": {
        "repo": "beardfacebeard/Ghost-ProtoClaw",
        "branch": "main"
      },
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npx prisma generate && npm run build"
      },
      "deploy": {
        "startCommand": "node scripts/start-production.mjs",
        "healthcheckPath": "/api/admin/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "public": true
      },
      "variables": {
        "NODE_ENV": "production",
        "SEED_ON_START": "true",
        "NIXPACKS_NODE_VERSION": "22",
        "NEXT_PUBLIC_APP_URL": "https://${{ RAILWAY_PUBLIC_DOMAIN }}",
        "DATABASE_URL": "${{ Postgres.DATABASE_URL }}",
        "DIRECT_URL": "${{ Postgres.DATABASE_URL }}",
        "SESSION_SECRET": "${{ secret(64) }}",
        "MAGIC_LINK_SECRET": "${{ secret(64) }}",
        "ENCRYPTION_KEY": "${{ secret(32) }}",
        "OPENCLAW_WEBHOOK_SECRET": "${{ shared.OPENCLAW_WEBHOOK_SECRET }}",
        "OPENCLAW_GATEWAY_URL": "https://${{ OpenClaw.RAILWAY_PUBLIC_DOMAIN }}",
        "OPENCLAW_GATEWAY_TOKEN": "${{ shared.OPENCLAW_GATEWAY_TOKEN }}",
        "MISSION_CONTROL_WORKSPACE_MIRROR_MODE": "database",
        "WORKSPACE_SYNC_MODE": "database",
        "MISSION_CONTROL_PROMPT_ASSIST_MODEL": "openrouter/openai/gpt-4o-mini",
        "RESEND_API_KEY": {
          "description": "API key from https://resend.com — used to send login links and invites. Sign up free at resend.com/signup.",
          "required": true
        },
        "OPENROUTER_API_KEY": {
          "description": "API key from https://openrouter.ai — your AI provider key. One key gives access to hundreds of models (OpenAI, Anthropic, Google, etc.).",
          "required": true
        },
        "MISSION_CONTROL_ADMIN_EMAIL": {
          "description": "Your email address — used for the initial admin account and password recovery.",
          "required": true
        },
        "MISSION_CONTROL_ADMIN_PASSWORD": {
          "description": "Choose a strong password for your admin account.",
          "required": true
        },
        "MISSION_CONTROL_ADMIN_NAME": {
          "description": "Your name (optional). Used as the admin display name and default organization name.",
          "required": false,
          "default": "Admin"
        }
      }
    },
    "OpenClaw": {
      "name": "OpenClaw",
      "description": "AI runtime engine — executes agents, tools, and workflows orchestrated by Ghost ProtoClaw.",
      "source": {
        "image": "ghcr.io/openclaw/openclaw:latest"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "public": true
      },
      "volumes": {
        "openclaw_data": {
          "mountPath": "/data"
        }
      },
      "variables": {
        "NODE_ENV": "production",
        "OPENCLAW_GATEWAY_PORT": "8080",
        "OPENCLAW_GATEWAY_TOKEN": "${{ shared.OPENCLAW_GATEWAY_TOKEN }}",
        "OPENCLAW_STATE_DIR": "/data/.openclaw",
        "OPENCLAW_WORKSPACE_DIR": "/data/workspace",
        "OPENCLAW_WEBHOOK_SECRET": "${{ shared.OPENCLAW_WEBHOOK_SECRET }}",
        "OPENROUTER_API_KEY": "${{ GhostProtoClaw.OPENROUTER_API_KEY }}"
      }
    },
    "Hermes": {
      "name": "Hermes",
      "description": "Lightweight task runner runtime — executes quick agent tasks and hooks.",
      "source": {
        "repo": "beardfacebeard/Ghost-ProtoClaw",
        "branch": "main",
        "rootDirectory": "runtimes/shared"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "public": false
      },
      "variables": {
        "RUNTIME_ID": "hermes",
        "API_KEY": "${{ shared.RUNTIME_API_KEY }}",
        "OPENROUTER_API_KEY": "${{ GhostProtoClaw.OPENROUTER_API_KEY }}",
        "DEFAULT_MODEL": "anthropic/claude-sonnet-4-20250514"
      }
    },
    "Codex": {
      "name": "Codex",
      "description": "Code-focused orchestration runtime — handles development and technical tasks.",
      "source": {
        "repo": "beardfacebeard/Ghost-ProtoClaw",
        "branch": "main",
        "rootDirectory": "runtimes/shared"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "public": false
      },
      "variables": {
        "RUNTIME_ID": "codex",
        "API_KEY": "${{ shared.RUNTIME_API_KEY }}",
        "OPENROUTER_API_KEY": "${{ GhostProtoClaw.OPENROUTER_API_KEY }}",
        "DEFAULT_MODEL": "anthropic/claude-sonnet-4-20250514"
      }
    },
    "ClaudeCode": {
      "name": "Claude Code",
      "description": "Anthropic-focused execution runtime — specialized for Claude model tasks.",
      "source": {
        "repo": "beardfacebeard/Ghost-ProtoClaw",
        "branch": "main",
        "rootDirectory": "runtimes/shared"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "public": false
      },
      "variables": {
        "RUNTIME_ID": "claude-code",
        "API_KEY": "${{ shared.RUNTIME_API_KEY }}",
        "OPENROUTER_API_KEY": "${{ GhostProtoClaw.OPENROUTER_API_KEY }}",
        "DEFAULT_MODEL": "anthropic/claude-sonnet-4-20250514"
      }
    }
  },
  "plugins": {
    "Postgres": {
      "name": "PostgreSQL",
      "plugin": "postgresql"
    }
  },
  "shared": {
    "OPENCLAW_WEBHOOK_SECRET": {
      "value": "${{ secret(32) }}",
      "description": "Shared secret for webhook communication. Auto-generated — do not change."
    },
    "OPENCLAW_GATEWAY_TOKEN": {
      "value": "${{ secret(64) }}",
      "description": "Shared bearer token for authenticated API calls. Auto-generated — do not change."
    },
    "RUNTIME_API_KEY": {
      "value": "${{ secret(32) }}",
      "description": "Shared API key for runtime services (Hermes, Codex, Claude Code). Auto-generated — do not change."
    }
  }
}
