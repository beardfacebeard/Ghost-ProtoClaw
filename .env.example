# Ghost ProtoClaw Mission Control — Environment Variables
# Copy this file to .env and fill in your values.
# Required variables must be set before the app will start.
#
# Legend:
#   [RAILWAY-AUTO]  = Automatically set by the Railway template — no action needed.
#   [RAILWAY-INPUT] = You enter this in the Railway deploy wizard.
#   [MANUAL]        = You must set this yourself for VPS / local deploys.

# -------------------------------------------------------------------
# Core URLs
# -------------------------------------------------------------------

# Required: Public HTTPS or local URL where Mission Control will run.
# [RAILWAY-AUTO] https://${{ RAILWAY_PUBLIC_DOMAIN }}
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Public URL for the OpenClaw control surface if you expose one separately.
NEXT_PUBLIC_OPENCLAW_CONTROL_URL=""

# Optional: Railway template link for the Mission Control service handoff.
NEXT_PUBLIC_RAILWAY_TEMPLATE_URL=""

# Optional: Railway template link for the OpenClaw Core service handoff.
NEXT_PUBLIC_OPENCLAW_RAILWAY_TEMPLATE_URL=""

# -------------------------------------------------------------------
# Admin Owner Recovery
# -------------------------------------------------------------------

# Required: Permanent recovery email for the owner account that can always regain access.
# [RAILWAY-INPUT] You enter this at deploy time.
MISSION_CONTROL_ADMIN_EMAIL="owner@example.com"

# Required: Password for the seed super_admin account. Use a strong unique password.
# [RAILWAY-INPUT] You enter this at deploy time.
MISSION_CONTROL_ADMIN_PASSWORD=""

# Optional: Display name for the default owner. Also used for the first seeded organization name.
# [RAILWAY-INPUT] You enter this at deploy time (optional).
MISSION_CONTROL_ADMIN_NAME="Admin"

# -------------------------------------------------------------------
# Sessions + Auth
# -------------------------------------------------------------------

# Required: Primary session signing secret for auth cookies and HMACs. Generate at least 64 characters.
# [RAILWAY-AUTO] Generated with ${{ secret(64) }}
# [MANUAL] Generate with: openssl rand -hex 32
SESSION_SECRET=""

# Optional: Legacy alias for SESSION_SECRET. Supported for compatibility with earlier scaffolding.
MISSION_CONTROL_SESSION_SECRET=""

# Optional: Session lifetime in days. Leave at 7 unless you want a shorter or longer login window.
SESSION_MAX_AGE_DAYS="7"

# Required: Long random secret used when generating and verifying magic link tokens.
# [RAILWAY-AUTO] Generated with ${{ secret(64) }}
# [MANUAL] Generate with: openssl rand -hex 32
MAGIC_LINK_SECRET=""

# -------------------------------------------------------------------
# Email (Resend)
# -------------------------------------------------------------------

# Required: Resend API key used to send login links, invites, and notifications.
# [RAILWAY-INPUT] Get yours free at https://resend.com/signup
RESEND_API_KEY=""

# Optional: Preferred sender identity for Resend emails. Defaults to Ghost ProtoClaw if omitted.
RESEND_FROM_EMAIL="Ghost ProtoClaw <noreply@ghostprotoclaw.com>"

# Optional: Legacy alias for RESEND_FROM_EMAIL.
EMAIL_FROM="mission-control@example.com"

# -------------------------------------------------------------------
# Database (PostgreSQL / Prisma)
# -------------------------------------------------------------------

# Required: Primary Postgres connection string for runtime queries.
# [RAILWAY-AUTO] Wired to ${{ Postgres.DATABASE_URL }}
# [MANUAL] Your Postgres connection string (e.g. postgresql://user:pass@host:5432/dbname)
DATABASE_URL=""

# Required: Direct Postgres connection string for Prisma migrations and schema operations.
# [RAILWAY-AUTO] Wired to ${{ Postgres.DATABASE_URL }} (same as DATABASE_URL on Railway)
# [MANUAL] Use a non-pooled / direct connection string if your provider uses connection pooling.
DIRECT_URL=""

# Optional: Password for the local Postgres container when using docker-compose.
POSTGRES_PASSWORD="change-me"

# -------------------------------------------------------------------
# OpenClaw Bridge
# -------------------------------------------------------------------

# Required: Base URL for the OpenClaw gateway that Mission Control manages.
# [RAILWAY-AUTO] Wired to https://${{ OpenClaw.RAILWAY_PUBLIC_DOMAIN }}
# [MANUAL] Your OpenClaw instance URL (e.g. http://localhost:8080)
OPENCLAW_GATEWAY_URL="http://localhost:8080"

# Optional: Gateway bearer token if you are authenticating with an env var instead of a token file.
OPENCLAW_GATEWAY_TOKEN=""

# Optional: Path to a mounted file that contains the OpenClaw gateway token.
OPENCLAW_GATEWAY_TOKEN_FILE=""

# Required: Shared secret used to verify inbound runtime events from OpenClaw.
# [RAILWAY-AUTO] Generated once with ${{ secret(32) }} and shared with the OpenClaw service.
# [MANUAL] Generate with: openssl rand -hex 16
OPENCLAW_WEBHOOK_SECRET=""

# Required: Absolute path to the shared OpenClaw workspace root on disk.
OPENCLAW_WORKSPACE_ROOT="/var/lib/openclaw/workspace"

# Required: Where Mission Control should mirror workspace files. Use either "disk" or "database".
MISSION_CONTROL_WORKSPACE_MIRROR_MODE="database"

# Workspace sync mode used by the admin UI for workspace management.
WORKSPACE_SYNC_MODE="database"

# Required when WORKSPACE_SYNC_MODE="disk": mounted shared workspace path.
# Examples: /app/workspace or ./workspace
WORKSPACE_BASE_PATH=""

# Required: Command used to invoke the OpenClaw CLI on this machine.
OPENCLAW_CLI_COMMAND="openclaw"

# -------------------------------------------------------------------
# AI / Prompt Assist
# -------------------------------------------------------------------

# Required: OpenRouter API key. Recommended default — supports free and paid models through one key.
# [RAILWAY-INPUT] Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Optional: Anthropic API key if you want direct Anthropic model support.
# OpenRouter is recommended instead — it includes Anthropic models and many others.
ANTHROPIC_API_KEY=""

# Optional: OpenAI API key if you want direct OpenAI provider support.
OPENAI_API_KEY=""

# Required: Default model slug used for prompt assist and builder generation helpers.
MISSION_CONTROL_PROMPT_ASSIST_MODEL="openrouter/openai/gpt-4o-mini"

# -------------------------------------------------------------------
# Encryption
# -------------------------------------------------------------------

# Required: AES-256-GCM encryption key used for integration secrets, webhook secrets, and deploy secrets.
# [RAILWAY-AUTO] Generated with ${{ secret(32) }}
# [MANUAL] Generate with: openssl rand -hex 16
ENCRYPTION_KEY=""

# Optional: Legacy alias for ENCRYPTION_KEY. Supported for compatibility with earlier scaffolding.
INTEGRATION_ENCRYPTION_KEY=""

# -------------------------------------------------------------------
# Optional Integrations
# -------------------------------------------------------------------

# Optional: Telegram bot token for approvals and notifications.
TELEGRAM_BOT_TOKEN=""

# Optional: Comma-separated Telegram chat IDs that are allowed to interact with Mission Control.
TELEGRAM_ALLOWED_CHAT_IDS=""

# Optional: Telegram channel or chat ID used for approval notifications.
TELEGRAM_APPROVALS_CHANNEL_ID=""

# Optional: Google OAuth client ID for Gmail, Calendar, and Drive connections.
GMAIL_CLIENT_ID=""

# Optional: Google OAuth client secret paired with the Gmail client ID.
GMAIL_CLIENT_SECRET=""

# Optional: Google refresh token if you are using a service-level Gmail integration.
GMAIL_REFRESH_TOKEN=""

# Optional: Preferred Google OAuth client ID for browser-based OAuth callback flows.
GOOGLE_CLIENT_ID=""

# Optional: Preferred Google OAuth client secret for browser-based OAuth callback flows.
GOOGLE_CLIENT_SECRET=""

# Optional: Full Google OAuth callback URL. Defaults to NEXT_PUBLIC_APP_URL + /api/auth/oauth/google/callback.
GOOGLE_REDIRECT_URI=""

# Optional: OpenRouter OAuth client ID for provider-managed OAuth handoffs.
OPENROUTER_CLIENT_ID=""

# Optional: OpenRouter OAuth client secret for provider-managed OAuth handoffs.
OPENROUTER_CLIENT_SECRET=""

# Optional: GoHighLevel API key for CRM and automation sync.
GHL_API_KEY=""

# Optional: GoHighLevel location ID for the account you want to connect.
GHL_LOCATION_ID=""

# Optional: Skool API key for community integrations.
SKOOL_API_KEY=""

# Optional: Public Skool community URL for the connected workspace.
SKOOL_COMMUNITY_URL=""

# Optional: Stripe secret key for billing and Stripe-connected workflows.
STRIPE_SECRET_KEY=""

# Optional: Stripe webhook signing secret for inbound Stripe events.
STRIPE_WEBHOOK_SIGNING_SECRET=""

# Optional: Emergent API key for Emergent integrations.
EMERGENT_API_KEY=""

# Optional: Emergent project slug associated with this deployment.
EMERGENT_PROJECT_SLUG=""

# Optional: Web search provider name such as "tavily".
WEB_SEARCH_PROVIDER=""

# Optional: API key for the configured web search provider.
WEB_SEARCH_API_KEY=""

# Optional: AWS access key ID for S3 uploads and downloads.
AWS_ACCESS_KEY_ID=""

# Optional: AWS secret access key for S3 uploads and downloads.
AWS_SECRET_ACCESS_KEY=""

# Optional: AWS region where your S3 bucket lives.
AWS_REGION=""

# Optional: S3 bucket name used for workspace exports and uploads.
AWS_S3_BUCKET=""

# -------------------------------------------------------------------
# Build / Runtime
# -------------------------------------------------------------------

# Optional: Railway and Nixpacks Node version override. Keep this at 22 for the recommended deployment target.
NIXPACKS_NODE_VERSION="22"

# Optional: Runtime mode. Use "development" locally and "production" in hosted environments.
NODE_ENV="development"
