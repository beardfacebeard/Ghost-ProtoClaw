datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id             String                    @id @default(cuid())
  name           String
  slug           String                    @unique
  planTier       String                    @default("app_only")
  // planTier: "app_only" | "founding_setup" | "founding_concierge" | "hosted"
  status         String                    @default("active")
  config         Json?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  businesses     Business[]
  integrations   Integration[]
  mcpServers     McpServer[]
  adminUsers     MissionControlAdminUser[]
  auditEvents    AuditEvent[]
  deployProfiles DeploymentProfile[]
  skills         Skill[]
  brandAssets       BrandAsset[]
  adCloneProducts  AdCloneProduct[]
  adCloneBrands    AdCloneBrand[]
  adCloneProjects  AdCloneProject[]
  propFirmProfiles PropFirmProfile[]
  attorneyProfiles AttorneyProfile[]
  deals            Deal[]
  dealSignals      DealSignal[]
  buyerProfiles    BuyerProfile[]
}

model Business {
  id                    String            @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String
  status                String            @default("planning")
  // status: "active" | "paused" | "planning" | "archived"
  health                Json?
  summary               String?
  brandVoice            String?
  primaryOwners         String?
  secondaryOwners       String?
  mainGoals             String?
  coreOffers            String?
  openTasks             String?
  recentSessions        String?
  systemPrompt          String?
  guardrails            String?
  offerAndAudienceNotes String?
  bannedClaims          String?
  safetyMode            String            @default("ask_before_acting")
  primaryModel          String?
  fallbackModel         String?
  modelSource           String            @default("system")
  // modelSource: "system" | "business" | "agent"
  // Jurisdiction drives broker availability, leverage caps, and the wording
  // of the mandatory risk disclosure for regulated templates (notably the
  // Forex Research & Execution Desk). Null for businesses that don't need
  // jurisdiction-aware behavior (marketing, content, etc.).
  jurisdiction          String?
  // jurisdiction: "US" | "UK" | "EU" | "AU" | "CA" | "SG" | "JP" | "OTHER"
  // Trading execution tier for regulated templates. Defaults to the safest
  // tier so a freshly-materialized business can never fire live orders.
  // Upgrading from research -> paper -> live_approval requires explicit
  // confirmation flows enforced in the UI and server-side.
  tradingMode           String            @default("research")
  // tradingMode: "research" | "paper" | "live_approval"
  // Deal execution tier for Dealhawk-style real-estate templates. Defaults
  // to the safest tier so a freshly-materialized Dealhawk business can never
  // generate seller outreach or binding contracts. Upgrading research ->
  // outreach requires a TCPA-compliance attestation; outreach -> contract
  // requires an AttorneyProfile on file for the property's state.
  dealMode              String            @default("research")
  // dealMode: "research" | "outreach" | "contract"
  // Timestamp + actor for the TCPA attestation that gates dealMode upgrades
  // from "research" to "outreach". Operator must attest to honoring DNC,
  // opt-outs, and state wholesaler-disclosure requirements before any SMS /
  // call / mail outreach fires.
  tcpaAttestedAt        DateTime?
  tcpaAttestedBy        String?
  currentIntegrations   Json?
  knowledgeBase         Json?
  config                Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  organization          Organization      @relation(fields: [organizationId], references: [id])
  agents                Agent[]
  workflows             Workflow[]
  webhookEndpoints      WebhookEndpoint[]
  knowledgeItems        KnowledgeItem[]
  agentMemories         AgentMemory[]
  conversationLogs      ConversationLog[]
  workspaceDocuments    WorkspaceDocument[]
  logEvents             LogEvent[]
  activityEntries       ActivityEntry[]
  approvalRequests      ApprovalRequest[]
  backups               Backup[]
  outcomeSnapshots      OutcomeSnapshot[]
  actionRuns            ActionRun[]
  projects              Project[]
  issues                Issue[]
  goals                 Goal[]
  telegramChats         TelegramChat[]
  brandAssets           BrandAsset[]
  adCloneProducts      AdCloneProduct[]
  adCloneBrands        AdCloneBrand[]
  adCloneProjects      AdCloneProject[]
  todos                 Todo[]
  propFirmProfiles      PropFirmProfile[]
  attorneyProfiles      AttorneyProfile[]
  deals                 Deal[]
  buyerProfiles         BuyerProfile[]
  prospects             Prospect[]
  prospectStageEvents   ProspectStageEvent[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Agent {
  id                String            @id @default(cuid())
  businessId        String?
  organizationId    String?
  parentAgentId     String?
  displayName       String
  emoji             String?
  role              String
  purpose           String?
  type              String            @default("specialist")
  // type: "main" | "specialist" | "global"
  status            String            @default("active")
  // status: "active" | "paused" | "warning" | "disabled"
  systemPrompt      String?
  roleInstructions  String?
  outputStyle       String?
  constraints       String?
  escalationRules   String?
  askBeforeDoing    String?
  primaryModel      String?
  fallbackModel     String?
  modelSource       String            @default("business")
  runtime           String            @default("openclaw")
  // runtime: "openclaw" | "hermes" | "opencode" | "codex" | "claude"
  safetyMode        String?
  tools             Json?
  config            Json?
  workspacePath     String?
  defaultAgent      Boolean           @default(false)
  depth             Int               @default(0)
  lastRun           DateTime?
  lastSeen          DateTime?
  lastOutputSummary String?
  sessionsCount     Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  business          Business?         @relation(fields: [businessId], references: [id])
  parent            Agent?            @relation("AgentHierarchy", fields: [parentAgentId], references: [id], onDelete: SetNull)
  children          Agent[]           @relation("AgentHierarchy")
  agentMemories     AgentMemory[]
  conversationLogs  ConversationLog[]
  approvalRequests  ApprovalRequest[]
  actionRuns        ActionRun[]
  assignedIssues    Issue[]           @relation("AgentIssues")
  maxTokensPerCall  Int?
  agentSkills       AgentSkill[]
  telegramChats     TelegramChat[]

  @@index([businessId])
  @@index([organizationId])
  @@index([parentAgentId])
}

model Workflow {
  id               String            @id @default(cuid())
  businessId       String
  organizationId   String?
  agentId          String?
  name             String
  description      String?
  enabled          Boolean           @default(true)
  trigger          String            @default("manual")
  // trigger: "manual"|"scheduled"|"webhook"|"new_email"|"new_lead"|"new_comment"
  output           String            @default("chat")
  // output: "chat"|"telegram"|"report"|"draft"|"crm_note"|"content_queue"
  // Kept for backward compatibility; the authoritative list is `outputs`.
  outputs          String[]          @default([])
  // outputs: the full fan-out list. When non-empty, takes precedence over
  // `output`. Each run delivers to every entry in this array.
  scheduleMode     String?
  // scheduleMode: "cron"|"every"|"definition_only"
  frequency        String?
  timezone         String?
  cronExpression   String?
  approvalMode     String?
  safetyMode       String?
  actionType       String?
  runtimeJobId     String?
  resultStatus     String?
  lastRunAt        DateTime?
  lastRunResult    Json?
  nextRunAt        DateTime?
  // nextRunAt: the in-process scheduler uses this for scheduled workflows.
  //   Set when a scheduled workflow is created/updated, advanced atomically
  //   by the scheduler just before each run so concurrent ticks can't
  //   double-fire. Null when the workflow has no active schedule.
  config           Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  business         Business          @relation(fields: [businessId], references: [id])
  webhookEndpoints WebhookEndpoint[]
  approvalRequests ApprovalRequest[]
  actionRuns       ActionRun[]

  @@index([businessId])
  @@index([organizationId])
  @@index([agentId])
  @@index([trigger, enabled, nextRunAt])
}

model WebhookEndpoint {
  id              String         @id @default(cuid())
  businessId      String
  workflowId      String?
  provider        String         @default("generic")
  // provider: "stripe"|"github"|"generic"|"custom"
  secret          String?
  encryptedSecret String?
  enabled         Boolean        @default(true)
  lastReceivedAt  DateTime?
  totalReceived   Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  business        Business       @relation(fields: [businessId], references: [id])
  workflow        Workflow?      @relation(fields: [workflowId], references: [id])
  events          WebhookEvent[]

  @@index([businessId])
  @@index([workflowId])
}

model WebhookEvent {
  id           String          @id @default(cuid())
  endpointId   String
  businessId   String
  provider     String
  eventType    String
  payload      Json
  rawBody      String?
  verified     Boolean         @default(false)
  status       String          @default("received")
  // status: "received"|"processing"|"completed"|"failed"
  dispatchedAt DateTime?
  processedAt  DateTime?
  error        String?
  createdAt    DateTime        @default(now())
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId])
  @@index([businessId])
}

model MissionControlAdminUser {
  id             String         @id @default(cuid())
  organizationId String?
  email          String         @unique
  displayName    String
  passwordHash   String?
  role           String         @default("admin")
  // role: "super_admin" | "admin"
  businessIds    String[]
  status         String         @default("active")
  // status: "active" | "pending" | "suspended"
  lastLoginAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  magicLinks     MagicLink[]

  @@index([organizationId])
}

model DeviceAccessRecord {
  id         String   @id @default(cuid())
  deviceId   String   @unique
  requestId  String?
  role       String?
  ipAddress  String?
  status     String   @default("pending")
  // status: "pending"|"approved"|"revoked"|"rejected"
  approvedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AgentMemory {
  id         String   @id @default(cuid())
  agentId    String
  businessId String
  type       String
  // type: "conversation_summary"|"learned_preference"|"contact_note"|"task_outcome"|"system_observation"
  content    String
  importance Int      @default(5)
  tier       String   @default("warm")
  // tier: "hot"|"warm"|"cold"
  expiresAt  DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agent      Agent    @relation(fields: [agentId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])

  @@index([agentId])
  @@index([businessId])
}

model KnowledgeItem {
  id         String   @id @default(cuid())
  businessId String
  category   String
  // category: "about_business"|"products_services"|"pricing"|"policies"|"faqs"|"contacts"|"brand_voice"|"processes"|"custom"
  title      String
  content    String
  sourceType String   @default("knowledge_base")
  // sourceType: "knowledge_base"|"file"|"external"
  enabled    Boolean  @default(true)
  tokenCount Int?
  // Three-tier loading strategy to keep token budgets in check:
  //   hot  — always injected into every agent's system prompt
  //   warm — injected only for agents whose id is in assignedAgentIds
  //          (empty array = all agents on the business, for back-compat)
  //   cold — never auto-injected; only retrieved on demand via the
  //          knowledge_lookup tool
  // Default is "warm" so existing data is untouched by the migration.
  tier                  String    @default("warm")
  assignedAgentIds      String[]  @default([])
  // Semantic search — text-embedding-3-small produces 1536-dim vectors.
  // Stored as Float[] (no pgvector dep) with in-app cosine similarity,
  // which is plenty fast for up to ~500 items per business. Null until
  // the item has been embedded (and when OpenAI isn't configured).
  embedding             Float[]   @default([])
  embeddingModel        String?
  embeddingGeneratedAt  DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([businessId, tier])
}

model ConversationLog {
  id           String    @id @default(cuid())
  agentId      String
  businessId   String
  adminUserId  String?
  title        String?
  channel      String?
  contactId    String?
  status       String    @default("active")
  // status: "active"|"completed"|"escalated"|"failed"
  messageCount Int       @default(0)
  summary      String?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agent        Agent     @relation(fields: [agentId], references: [id])
  business       Business       @relation(fields: [businessId], references: [id])
  messages       Message[]
  telegramChats  TelegramChat[]

  @@index([agentId])
  @@index([businessId])
  @@index([adminUserId])
}

model Message {
  id             String          @id @default(cuid())
  conversationId String
  role           String
  // role: "user"|"assistant"|"system"
  content        String
  tokenCount     Int?
  model          String?
  latencyMs      Int?
  metadata       Json?
  attachments    Json?
  // attachments: Array<{ id, fileName, fileType, fileSize, url }>
  createdAt      DateTime        @default(now())
  conversation   ConversationLog @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model BrandAsset {
  id             String       @id @default(cuid())
  organizationId String
  businessId     String
  fileName       String
  fileType       String
  // fileType: "image"|"document"|"video"|"audio"|"other"
  mimeType       String
  fileSize       Int
  storageKey     String
  // storageKey: S3 key or local path
  url            String?
  description    String?
  category       String       @default("general")
  // category: "logo"|"brand_guide"|"product_image"|"marketing"|"document"|"general"
  tags           String[]
  uploadedBy     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  business       Business     @relation(fields: [businessId], references: [id])

  @@index([organizationId])
  @@index([businessId])
  @@index([category])
}

model AdCloneProduct {
  id             String           @id @default(cuid())
  organizationId String
  businessId     String
  name           String
  image          String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id])
  business       Business         @relation(fields: [businessId], references: [id])
  adCloneProjects AdCloneProject[]

  @@index([organizationId])
  @@index([businessId])
}

model AdCloneBrand {
  id             String           @id @default(cuid())
  organizationId String
  businessId     String
  name           String
  font           String?
  colors         String?
  website        String?
  logoUrl        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id])
  business       Business         @relation(fields: [businessId], references: [id])
  adCloneProjects AdCloneProject[]

  @@index([organizationId])
  @@index([businessId])
}

model AdCloneProject {
  id               String          @id @default(cuid())
  organizationId   String
  businessId       String
  name             String
  status           String          @default("draft")
  // status: "draft"|"in_progress"|"editing"|"finalized"
  productId        String?
  brandId          String?
  inputAdUrl       String?
  inputAdNotes     String?
  aiVersion1Url    String?
  aiVersion2Url    String?
  aiVersion3Url    String?
  aiVersion4Url    String?
  aiVersion5Url    String?
  chosenFavoriteUrl String?
  editsRound1      String?
  editedImage1Url  String?
  editsRound2      String?
  editedImage2Url  String?
  finalImageUrl    String?
  videoUrl         String?
  resized916Url    String?
  resized11Url     String?
  resized43Url     String?
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organization     Organization    @relation(fields: [organizationId], references: [id])
  business         Business        @relation(fields: [businessId], references: [id])
  product          AdCloneProduct? @relation(fields: [productId], references: [id])
  brand            AdCloneBrand?   @relation(fields: [brandId], references: [id])

  @@index([organizationId])
  @@index([businessId])
  @@index([productId])
  @@index([brandId])
  @@index([status])
}

model TelegramChat {
  id               String          @id @default(cuid())
  telegramChatId   String
  organizationId   String
  agentId          String
  businessId       String
  conversationId   String?
  telegramUsername  String?
  displayName      String?
  role             String          @default("admin")
  // role: "admin"|"contact"
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  agent            Agent           @relation(fields: [agentId], references: [id])
  business         Business        @relation(fields: [businessId], references: [id])
  conversation     ConversationLog? @relation(fields: [conversationId], references: [id])

  @@unique([telegramChatId, agentId])
  @@index([telegramChatId])
  @@index([organizationId])
  @@index([businessId])
}

model WorkspaceDocument {
  id         String   @id @default(cuid())
  businessId String
  agentId    String?
  filePath   String
  content    String
  category   String   @default("other")
  // category: "core"|"knowledge"|"memory"|"timeline"|"other"
  tier       String   @default("warm")
  // tier: "hot"|"warm"|"cold"
  syncStatus String   @default("pending")
  // syncStatus: "synced"|"pending"|"unavailable"
  syncTarget String   @default("database")
  // syncTarget: "disk"|"database"
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([agentId])
}

model Integration {
  id                  String       @id @default(cuid())
  organizationId      String
  key                 String
  name                String
  description         String?
  scope               String       @default("organization")
  // scope: "organization"|"business"
  status              String       @default("disconnected")
  // status: "connected"|"disconnected"|"error"
  authType            String       @default("api_key")
  // authType: "api_key"|"oauth"|"bearer"
  secretKeys          String[]
  encryptedSecrets    Json?
  config              Json?
  assignedBusinessIds String[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
}

model McpServer {
  id              String       @id @default(cuid())
  organizationId  String
  businessId      String?
  definitionId    String
  name            String
  status          String       @default("installing")
  // status: "installing"|"active"|"error"|"disabled"
  config          Json?
  encryptedConfig Json?
  healthStatus    Json?
  lastHealthCheck DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([businessId])
}

model ApprovalRequest {
  id           String    @id @default(cuid())
  businessId   String
  agentId      String?
  workflowId   String?
  actionType   String
  actionDetail Json?
  status       String    @default("pending")
  // status: "pending"|"approved"|"rejected"|"expired"|"auto_approved"
  requestedBy  String?
  reviewedBy   String?
  reason       String?
  expiresAt    DateTime
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  business     Business  @relation(fields: [businessId], references: [id])
  agent        Agent?    @relation(fields: [agentId], references: [id])
  workflow     Workflow? @relation(fields: [workflowId], references: [id])

  @@index([businessId])
  @@index([agentId])
  @@index([workflowId])
}

model Backup {
  id             String    @id @default(cuid())
  organizationId String?
  businessId     String?
  sourceType     String
  // sourceType: "gateway_config"|"workspace_file"|"workspace_snapshot"|"export_bundle"
  scopeType      String?
  scopeId        String?
  status         String    @default("pending")
  // status: "pending"|"completed"|"failed"
  payload        Json?
  triggeredBy    String?
  reason         String?
  createdAt      DateTime  @default(now())
  business       Business? @relation(fields: [businessId], references: [id])

  @@index([organizationId])
  @@index([businessId])
}

model LogEvent {
  id         String    @id @default(cuid())
  businessId String?
  level      String    @default("info")
  // level: "info"|"warning"|"error"
  message    String
  action     String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  business   Business? @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model AuditEvent {
  id             String        @id @default(cuid())
  organizationId String?
  actorUserId    String?
  actorEmail     String?
  eventType      String
  entityType     String
  entityId       String?
  beforeJson     Json?
  afterJson      Json?
  ipAddress      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ActivityEntry {
  id         String    @id @default(cuid())
  businessId String?
  type       String
  // type: "workflow"|"approval"|"backup"|"integration"|"agent"|"system"
  title      String
  detail     String?
  status     String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  business   Business? @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model ActionRun {
  id          String    @id @default(cuid())
  businessId  String?
  agentId     String?
  workflowId  String?
  action      String
  status      String    @default("pending")
  // status: "pending"|"running"|"completed"|"failed"|"unsupported"
  reason      String?
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  business    Business? @relation(fields: [businessId], references: [id])
  agent       Agent?    @relation(fields: [agentId], references: [id])
  workflow    Workflow? @relation(fields: [workflowId], references: [id])

  @@index([businessId])
  @@index([agentId])
  @@index([workflowId])
}

model OutcomeSnapshot {
  id         String   @id @default(cuid())
  businessId String
  date       DateTime
  metrics    Json
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model MagicLink {
  id        String                    @id @default(cuid())
  email     String
  userId    String?
  tokenHash String                    @unique
  type      String                    @default("login")
  // type: "login"|"invite"|"reset"
  used      Boolean                   @default(false)
  metadata  Json?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                  @default(now())
  user      MissionControlAdminUser?  @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([userId])
}

model DeploymentProfile {
  id                 String        @id @default(cuid())
  organizationId     String?
  name               String
  description        String?
  publicEnv          Json?
  encryptedSecretEnv String?
  deployTarget       String        @default("railway")
  // deployTarget: "railway"|"vps"|"local"
  status             String        @default("draft")
  // status: "draft"|"active"|"deployed"
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Project {
  id             String    @id @default(cuid())
  businessId     String
  name           String
  description    String?
  status         String    @default("active")
  // status: "active" | "completed" | "archived"
  targetDate     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  business       Business  @relation(fields: [businessId], references: [id])
  issues         Issue[]

  @@index([businessId])
}

model Issue {
  id              String    @id @default(cuid())
  businessId      String
  projectId       String?
  assigneeAgentId String?
  title           String
  description     String?
  status          String    @default("open")
  // status: "open" | "in_progress" | "review" | "done" | "cancelled"
  priority        String    @default("medium")
  // priority: "urgent" | "high" | "medium" | "low"
  labels          String[]
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  business        Business  @relation(fields: [businessId], references: [id])
  project         Project?  @relation(fields: [projectId], references: [id])
  assigneeAgent   Agent?    @relation("AgentIssues", fields: [assigneeAgentId], references: [id])

  @@index([businessId])
  @@index([projectId])
  @@index([assigneeAgentId])
  @@index([status])
}

model Goal {
  id             String    @id @default(cuid())
  businessId     String
  parentGoalId   String?
  title          String
  description    String?
  status         String    @default("active")
  // status: "active" | "completed" | "paused" | "cancelled"
  progress       Int       @default(0)
  // progress: 0-100
  targetDate     DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  business       Business  @relation(fields: [businessId], references: [id])
  parent         Goal?     @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  children       Goal[]    @relation("GoalHierarchy")

  @@index([businessId])
  @@index([parentGoalId])
}

model Skill {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       String       @default("general")
  // category: "general" | "communication" | "analysis" | "automation" | "integration"
  instructions   String?
  config         Json?
  isRequired     Boolean      @default(false)
  status         String       @default("active")
  // status: "active" | "archived"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  agentSkills    AgentSkill[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model AgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillId   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([skillId])
}

// ---------------------------------------------------------------------------
// Token Usage & Budget Tracking
// ---------------------------------------------------------------------------

model TokenUsageLog {
  id               String   @id @default(cuid())
  organizationId   String
  businessId       String?
  agentId          String?
  model            String
  provider         String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  endpoint         String?
  // endpoint: "agent_test" | "workflow_run" | "hook" | "orchestrate" | "execute"
  success          Boolean  @default(true)
  latencyMs        Int?
  createdAt        DateTime @default(now())

  @@index([organizationId])
  @@index([businessId])
  @@index([agentId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
}

model BudgetConfig {
  id                String   @id @default(cuid())
  organizationId    String
  businessId        String?
  monthlyLimitUsd   Float    @default(50)
  alertThresholdPct Int      @default(80)
  // alertThresholdPct: 0-100, percentage of monthlyLimitUsd that triggers alert
  hardStop          Boolean  @default(false)
  // hardStop: if true, block LLM calls when budget exceeded
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([organizationId, businessId])
  @@index([organizationId])
}

model Todo {
  id                      String    @id @default(cuid())
  organizationId          String
  businessId              String
  // type: "idea" (fuzzy brain-dump) | "todo" (concrete actionable)
  type                    String    @default("todo")
  title                   String
  description             String?
  // status: "captured" | "active" | "snoozed" | "done" | "dismissed"
  status                  String    @default("captured")
  // priority: "low" | "medium" | "high" | "urgent"
  priority                String    @default("medium")
  agentId                 String?
  dueAt                   DateTime?
  snoozedUntil            DateTime?
  // createdVia: "web" | "telegram" | "agent" | "api" | "discord"
  createdVia              String    @default("web")
  createdBy               String?
  // createdByAgentId — set when an agent proposed this todo via the
  //   propose_todo tool. Distinguishes agent-suggested items from
  //   user-captured ones in the UI.
  createdByAgentId        String?
  // delegatedConversationId — set when the todo is activated and
  //   becomes a delegation. Lets the UI link back to the running task.
  delegatedConversationId String?
  activatedAt             DateTime?
  completedAt             DateTime?
  tags                    String[]  @default([])
  // recurringPattern — plain-English like "weekly", "every Monday".
  //   Present when the item reads like a recurring task. When the user
  //   clicks promote-to-workflow, this hints at the cron expression.
  recurringPattern        String?
  // remindedAt — last time we pinged the user about this on Telegram
  //   (so we don't spam on every scheduler tick).
  remindedAt              DateTime?
  metadata                Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  business                Business  @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, type, status])
  @@index([businessId, dueAt])
  @@index([businessId, snoozedUntil])
}

// YouTube Data API v3 quota ledger. Default project-level quota is 10 000
// units/day — an upload costs 1600, metadata update 50, list 3, analytics
// roughly free. We increment unitsUsed before every call so the caller can
// preflight "would this blow the cap" and surface a clean error instead
// of mid-upload failure. Rolls over per UTC date — `date` is DATE, not
// TIMESTAMP, so the natural key is [organizationId, date].
model YouTubeQuotaUsage {
  id             String   @id @default(cuid())
  organizationId String
  date           DateTime @db.Date
  unitsUsed      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, date])
  @@index([organizationId])
}

// Prop-firm profile attached to a Forex Research & Execution Desk business.
// Loads the firm's ruleset (Apex / FTMO / FundedNext / etc.) so the Risk
// Gate Agent + Prop-Firm Compliance Agent can check distance-to-bust on
// every proposed order. Only one profile active per business at a time.
//
// The ruleset itself is stored as JSON so we can evolve the schema of
// specific rules (static vs trailing DD, consistency %, minimum trading
// days) without migrations. Default presets live in
// lib/trading/prop-firm-presets.ts — selecting a preset copies the JSON
// into rules.
model PropFirmProfile {
  id               String   @id @default(cuid())
  organizationId   String
  businessId       String
  /// Registered firm key (e.g., "apex", "ftmo", "fundednext"). Matches
  /// a preset in lib/trading/prop-firm-presets.ts unless it's "custom".
  firmKey          String
  /// User-facing plan name (e.g., "Apex $50k Performance", "FTMO Classic 2-Step 100k").
  planName         String
  /// Starting account balance in USD. Used as the reference point for
  /// drawdown math (static / dynamic / trailing).
  startingBalance  Float
  /// High-water-mark balance — the Risk Gate updates this whenever a
  /// paper / live fill pushes the account above the current mark. Used
  /// for trailing drawdown computation.
  highWaterMark    Float
  /// Full rule JSON (see lib/trading/prop-firm-presets.ts for the shape).
  rules            Json
  /// Whether the profile is the active one for the business. Only one
  /// PropFirmProfile per business should have isActive=true at a time.
  isActive         Boolean  @default(true)
  /// Current state: "active" | "warning" | "busted" | "passed" | "archived"
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id])
  business         Business     @relation(fields: [businessId], references: [id])

  @@index([organizationId])
  @@index([businessId])
  @@index([businessId, isActive])
}

/// Attorney on file for a specific state per Dealhawk business. Required
/// to upgrade dealMode from "outreach" to "contract" for any property in
/// that state. One active AttorneyProfile per (businessId, state).
model AttorneyProfile {
  id                 String   @id @default(cuid())
  organizationId     String
  businessId         String
  /// 2-letter USPS state code (e.g., "TX", "FL", "CA"). Matches the
  /// state-disclosures matrix in lib/dealhawk/state-disclosures.ts.
  state              String
  /// Attorney legal name.
  name               String
  /// Firm name (optional — solo practitioners may not have one).
  firmName           String?
  /// Primary contact email.
  email              String
  /// Primary contact phone.
  phone              String?
  /// Bar number — operator-entered; not validated by the app.
  barNumber          String?
  /// Timestamp when operator marked the attorney as verified (they've
  /// confirmed the bar status themselves or uploaded proof). Null means
  /// the profile is on file but hasn't been attested as verified.
  licenseVerifiedAt  DateTime?
  /// Only one AttorneyProfile per (businessId, state) should be active.
  isActive           Boolean  @default(true)
  /// Free-form operator notes (e.g., "specializes in Sub-To, charges $450/hr").
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id])
  business           Business     @relation(fields: [businessId], references: [id])

  /// Application invariant: only one AttorneyProfile per
  /// (businessId, state) should have isActive=true at a time. Enforced in
  /// application code (see lib/dealhawk/attorney.ts), not via a DB unique
  /// constraint — this lets operators archive multiple historical attorneys
  /// per state without violating uniqueness.
  @@index([organizationId])
  @@index([businessId])
  @@index([businessId, state])
  @@index([businessId, state, isActive])
}

/// A real-estate deal row in the Dealhawk pipeline. Stages:
/// lead -> contacted -> qualified -> under_contract -> assigned -> closed
/// or dead. Every Deal is scoped to one Business.
model Deal {
  id                   String   @id @default(cuid())
  organizationId       String
  businessId           String
  /// Pipeline stage. Enum values:
  /// "lead" | "contacted" | "qualified" | "under_contract"
  /// | "assigned" | "closed" | "dead"
  status               String   @default("lead")
  /// Property address (street + unit). Normalized display form.
  propertyAddress      String
  propertyCity         String
  /// 2-letter USPS state code.
  propertyState        String
  propertyZip          String
  /// "sfr" | "multi_family" | "condo" | "townhouse" | "mobile"
  /// | "land" | "commercial"
  propertyType         String   @default("sfr")
  bedrooms             Int?
  bathrooms            Float?
  livingSqft           Int?
  lotSqft              Int?
  yearBuilt            Int?
  /// Owner of record (from tax assessor or operator input).
  ownerName            String?
  /// Owner mailing address — different from propertyAddress means
  /// absentee.
  ownerMailingAddress  String?
  ownerPhone           String?
  ownerEmail           String?
  /// "individual" | "llc" | "trust" | "estate" | "corporation"
  ownerEntityType      String?
  /// Comp Analyst output: ARV range.
  arvLow               Float?
  arvMid               Float?
  arvHigh              Float?
  /// Comp Analyst output: monthly rent estimate.
  rentEstimate         Float?
  /// Repair Cost Estimator output: three scenarios (conservative ends).
  rehabLight           Float?
  rehabMedium          Float?
  rehabHeavy           Float?
  /// Four simultaneous MAOs (Comp Analyst + decision tree).
  maoWholesale         Float?
  maoBrrrr             Float?
  maoFlip              Float?
  /// Sub-To Qualifier output: 1-100 fit score.
  subToScore           Int?
  /// "grand_slam" | "good" | "marginal" | "decline"
  subToViability       String?
  /// Distress Signal Analyst output: 1-100 motivation score.
  motivationScore      Int      @default(0)
  /// "wholesale" | "brrrr" | "flip" | "sub_to" | "novation"
  /// | "wrap" | "lease_option" | "contract_for_deed" | "decline"
  recommendedExit      String?
  /// "mls_stale" | "off_market" | "distress" | "absentee"
  /// | "manual_import" | "referral"
  source               String?
  /// Source-specific reference (e.g., MLS ID, NOD case number).
  sourceRef            String?
  /// Outreach state tracking.
  firstContactAt       DateTime?
  lastContactAt        DateTime?
  nextTouchAt          DateTime?
  contactAttempts      Int      @default(0)
  /// "no_response" | "not_interested" | "wanted_time"
  /// | "objection" | "warm" | "closed"
  sellerResponseState  String?
  /// Contract execution (populated only once dealMode = "contract").
  contractSignedAt     DateTime?
  /// "assignment" | "double_close" | "sub_to" | "novation"
  /// | "wrap" | "lease_option" | "contract_for_deed"
  contractType         String?
  purchasePrice        Float?
  assignmentFee        Float?
  /// Free-form operator / agent notes.
  notes                String?
  /// Flexible JSON for per-source metadata, scraping context, etc.
  config               Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id])
  business             Business     @relation(fields: [businessId], references: [id])
  signals              DealSignal[]

  @@index([organizationId])
  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, motivationScore])
  @@index([propertyState])
}

/// A single distress signal attached to a Deal. Signals stack to produce
/// the Deal.motivationScore. Every signal cites its source.
model DealSignal {
  id               String   @id @default(cuid())
  organizationId   String
  dealId           String
  /// "pre_foreclosure" | "tax_delinquent" | "probate" | "divorce"
  /// | "code_violation" | "vacancy" | "absentee" | "eviction"
  /// | "expired_listing" | "high_equity" | "long_tenure"
  signalType       String
  /// "public_record" | "mls" | "off_market_scrape" | "manual"
  /// | "batchdata" | "propstream"
  sourceType       String
  /// Source-specific identifier (e.g., NOD case number, MLS ID).
  sourceRef        String?
  /// Date the signal was cited from the source (e.g., filing date).
  citedDate        DateTime?
  /// Base weight contribution to motivationScore (pre-multiplier).
  weight           Int
  /// "high" | "medium" | "low"
  confidence       String   @default("medium")
  notes            String?
  createdAt        DateTime @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id])
  deal             Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([dealId])
  @@index([dealId, signalType])
}

/// Cash-buyer / landlord / flipper in the operator's buyer database.
/// Built and maintained by the Buyer List Builder agent (Agent 12) from
/// recent cash-sale records, REI club scraping, and operator imports.
/// The Disposition Agent (Agent 13) sorts the active set by zip × buy-box
/// when a deal is locked up to produce the A-list for the disposition
/// blast.
model BuyerProfile {
  id                String   @id @default(cuid())
  organizationId    String
  businessId        String
  /// Buyer's full name. Required.
  name              String
  /// LLC / company name if the buyer operates through an entity.
  llc               String?
  /// Primary contact channel. "email" | "phone" | "sms" | "other".
  contactMethod     String   @default("email")
  email             String?
  phone             String?
  /// Buy-box: "flip" | "brrrr" | "section_8" | "high_end" | "any".
  buyBox            String   @default("any")
  /// Zip codes the buyer targets. Stored as JSON string array.
  zipPreferences    Json?
  /// Min / max purchase price the buyer typically transacts in.
  minPurchasePrice  Float?
  maxPurchasePrice  Float?
  /// Max rehab tolerance: "light" | "medium" | "heavy" | "any".
  preferredRehabLevel String  @default("any")
  /// Financing type: "cash" | "hard_money" | "dscr" | "private" | "any".
  financingType     String   @default("cash")
  /// Last completed deal date — drives "stopped buying" flagging in the
  /// Buyer List Builder's monthly refresh.
  lastDealDate      DateTime?
  /// Number of deals closed in the operator's market in the last 12
  /// months. Updated when the operator marks a deal as closed.
  dealsLast12Mo     Int      @default(0)
  /// "active" | "archived" — soft delete via archived.
  status            String   @default("active")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id])
  business          Business     @relation(fields: [businessId], references: [id])

  @@index([organizationId])
  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, buyBox])
}

/// TipTax-style outreach prospect with funnel stage tracking. Used by the
/// Credit Recovery Outreach (Funnel A) playbook in tiptax_affiliate_engine
/// — Hunter writes a row when sourcing, Qualifier records tier + fit score,
/// Channel Operator transitions to "contacted" on send, Reply Triager
/// transitions to "replied"/"engaged" + records buyer state + engagement
/// score, Link Closer transitions to "link_sent". Stage column drives the
/// dashboard's funnel drop-off widget; ProspectStageEvent records every
/// transition for trajectory analysis.
model Prospect {
  id                    String   @id @default(cuid())
  businessId            String
  /// Identity / dedupe key
  businessName          String
  state                 String?
  metro                 String?
  email                 String?
  phone                 String?
  website               String?
  /// Discovery context (filled by Hunter)
  sourceType            String?
  /// "google_places" | "yelp" | "state_liquor" | "state_health" | "osm" | "manual"
  sourceUrl             String?
  cuisine               String?
  /// "full_bar" | "beer_wine" | "none" | "unknown"
  liquorClass           String?
  seatsEstimate         Int?
  reviewCount           Int?
  /// Fit scoring (filled by Qualifier)
  tier                  String?
  /// "A" | "B" | "C" | null — null while pre-qualified
  fitScore              Int?
  fitNotes              Json?
  estimatedRecoveryBand String?
  multiUnitFlag         Boolean  @default(false)
  /// Engagement (updated per reply by Reply Triager)
  buyerState            String?
  /// "unaware" | "curious-skeptical" | "interested-busy" | "CPA-dependent"
  /// | "ERC-sensitive" | "asking-but-not-committed" | "high-intent" |
  /// "qualified-but-stalled"
  engagementScore       Int?
  /// 0-100 per the Engagement Scoring Rubric KB
  engagementTier        String?
  /// "Hot" | "Warm" | "Cool"
  fallingTrust          Boolean  @default(false)
  /// Lifecycle stage — drives funnel drop-off widget
  stage                 String   @default("sourced")
  /// stages: "sourced" | "qualified" | "contacted" | "replied" |
  /// "engaged" | "link_sent" | "form_started" | "form_completed" |
  /// "accepted" | "dead" | "stalled"
  stageReason           String?
  /// Channel context
  primaryChannel        String?
  /// First channel that touched the prospect — informs follow-up rotation
  contactedChannels     Json?
  /// JSON string array — every channel we've sent on
  utmCampaign           String?
  utmContent            String?
  /// Per-stage timestamps (sparse — null until that stage is reached)
  sourcedAt             DateTime @default(now())
  qualifiedAt           DateTime?
  contactedAt           DateTime?
  repliedAt             DateTime?
  engagedAt             DateTime?
  linkSentAt            DateTime?
  formStartedAt         DateTime?
  formCompletedAt       DateTime?
  acceptedAt            DateTime?
  deadAt                DateTime?
  stalledAt             DateTime?
  lastTransitionAt      DateTime @default(now())
  /// Free-form notes (operator overrides, escalation context, etc.)
  notes                 String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  business              Business             @relation(fields: [businessId], references: [id])
  stageEvents           ProspectStageEvent[]

  @@index([businessId, stage])
  @@index([businessId, tier])
  @@index([businessId, lastTransitionAt])
  @@index([businessId, state])
  @@index([businessId, email])
  @@index([businessId, phone])
}

/// One row per stage transition. Lets Data Analyst reconstruct the trajectory
/// of any prospect (sourced → qualified → contacted → replied → engaged → ...)
/// and compute time-in-stage for the leakiest-stage report.
model ProspectStageEvent {
  id          String   @id @default(cuid())
  prospectId  String
  businessId  String
  fromStage   String?
  toStage     String
  reason      String?
  /// Optional context — e.g. {channel: "instantly", buyer_state, engagement_score}
  metadata    Json?
  createdAt   DateTime @default(now())
  prospect    Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  business    Business @relation(fields: [businessId], references: [id])

  @@index([prospectId, createdAt])
  @@index([businessId, createdAt])
  @@index([businessId, toStage])
}

